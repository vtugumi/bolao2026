generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  predictions      Prediction[]
  bonusPredictions BonusPrediction[]
  createdGroups    PrivateGroup[]    @relation("GroupCreator")
  groupMembers     GroupMember[]
}

model Team {
  id         Int     @id @default(autoincrement())
  name       String  @unique
  code       String  @unique
  flagEmoji  String  @default("")
  groupLabel String?

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  wonMatches  Match[] @relation("MatchWinner")
}

model Match {
  id          Int      @id @default(autoincrement())
  matchNumber Int      @unique
  stage       String
  groupLabel  String?
  dateTime    DateTime
  venue       String?

  homeTeamId Int?
  awayTeamId Int?
  homeTeam   Team? @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team? @relation("AwayTeam", fields: [awayTeamId], references: [id])

  homeScore     Int?
  awayScore     Int?
  winnerId      Int?
  winner        Team?  @relation("MatchWinner", fields: [winnerId], references: [id])
  homePenalties Int?
  awayPenalties Int?

  predictions Prediction[]
}

model Prediction {
  id        Int      @id @default(autoincrement())
  userId    Int
  matchId   Int
  homeScore Int
  awayScore Int
  winnerId  Int?
  points    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}

model BonusPrediction {
  id     Int    @id @default(autoincrement())
  userId Int
  type   String
  value  String
  points Int?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model Setting {
  key   String @id
  value String
}

model PrivateGroup {
  id         Int       @id @default(autoincrement())
  name       String
  inviteCode String    @unique
  creatorId  Int
  createdAt  DateTime  @default(now())
  creator    User      @relation("GroupCreator", fields: [creatorId], references: [id])
  members    GroupMember[]
}

model GroupMember {
  id       Int      @id @default(autoincrement())
  userId   Int
  groupId  Int
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  group    PrivateGroup @relation(fields: [groupId], references: [id])
  @@unique([userId, groupId])
}
